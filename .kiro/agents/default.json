{
  "name": "kaze-dev",
  "description": "Development agent for Kaze no Manga",
  "prompt": "file://../prompts/kaze-dev.md",
  "resources": ["file://README.md", "file://.kiro/specs/**/*.md", "file://.kiro/steering/**/*.md"],
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "allowedTools": [
    "read",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".kiro/**",
        ".github/**",
        "src/**",
        "drizzle/**",
        "public/**",
        "README.md",
        "CHANGELOG.md",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "vite.config.ts",
        "drizzle.config.ts",
        "biome.json",
        "vercel.json",
        "components.json",
        ".editorconfig",
        ".gitignore",
        ".env.example"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [".*git commit.*", ".*git push.*", ".*git tag .*", ".*npm publish.*"]
    }
  }
}
