{
  "name": "kaze-no-manga",
  "private": true,
  "version": "0.0.0",
  "description": "Cross-device manga reading tracker — monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "infra"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "pretest": "npm run build",
    "test": "vitest run",
    "posttest": "npm run clean",
    "pretest:coverage": "npm run build",
    "test:coverage": "vitest run --coverage",
    "posttest:coverage": "npm run clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "infra:deploy": "npm run deploy --workspace=infra",
    "infra:synth": "npm run synth --workspace=infra",
    "web:dev": "npm run dev --workspace=apps/web"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.8.3",
    "vitest": "3.1.3"
  },
  "license": "MIT"
}
